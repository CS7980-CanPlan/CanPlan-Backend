# CDK deployment regions. Source .env before CDK commands to use these values.
CANPLAN_BACKEND_REGION=ca-central-1
CANPLAN_KNOWLEDGE_BASE_REGION=us-east-1

# Personal CDK environment owner. Used by cdk:deploy:me and cdk:destroy:me.
# Use lowercase letters, numbers, and hyphens only. Do not use dev/prod/sandbox.
CDK_OWNER=michael

# Optional AWS CLI default region
AWS_REGION=ca-central-1

# Optional local API smoke-test values.
# Fill these after CDK deploy outputs them.
GRAPHQL_API_URL=your_graphql_api_url_here
GRAPHQL_API_KEY=your_graphql_api_key_here

# Optional local script config.
# Example: CanPlanTasks-sandbox, CanPlanTasks-dev, or CanPlanTasks-prod
DYNAMODB_TABLE_NAME=CanPlanTasks-sandbox

# Backend-only HMAC secret that signs AI report draft tokens (generateReport -> saveReport).
# REQUIRED for dev/prod deploys (synth fails without it); personal/sandbox fall back to a
# dev-only default. Generate a strong value, e.g. `openssl rand -base64 32`.
# REPORT_DRAFT_SIGNING_SECRET=change-me-to-a-strong-random-value

# Amazon Bedrock for generateTaskSteps. CDK deploys the Knowledge Base to
# CANPLAN_KNOWLEDGE_BASE_REGION and sets the Lambda's BEDROCK_REGION to match.
# Note: the org SCP on this account may deny newer Claude models / inference
# profiles — widen it before relying on Sonnet 4.6 in production.
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
# BEDROCK_MAX_TOKENS=1024

# Do not store AWS credentials here.
# Use AWS SSO:
# aws sso login --profile canplan-sandbox
# export AWS_PROFILE=canplan-sandbox
