# AWS deployment region
AWS_REGION=ca-central-1

# Optional local API smoke-test values.
# Fill these after CDK deploy outputs them.
GRAPHQL_API_URL=your_graphql_api_url_here
GRAPHQL_API_KEY=your_graphql_api_key_here

# Optional local script config.
# Example: CanPlanTasks-sandbox, CanPlanTasks-dev, or CanPlanTasks-prod
DYNAMODB_TABLE_NAME=CanPlanTasks-sandbox

# Amazon Bedrock for the askAi mutation. Inference runs in us-east-1 (where the
# US Claude inference profile lives) even though the rest of the backend is in
# ca-central-1. Override the region/model per environment if needed.
# Note: the org SCP on this account may deny newer Claude models / inference
# profiles — widen it before relying on Sonnet 4.6 in production.
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
# BEDROCK_MAX_TOKENS=1024

# Do not store AWS credentials here.
# Use AWS SSO:
# aws sso login --profile canplan-sandbox
# export AWS_PROFILE=canplan-sandbox