# CanPlan Admin Web Portal — environment configuration.
#
# Copy this file to `.env.local` and fill in the values from the backend CDK deploy
# outputs (see the backend README "Deploy" section). All four are REQUIRED — the app
# fails fast on startup if any is missing. Vite only exposes variables prefixed VITE_.

# AWS region the Cognito User Pool + AppSync API are deployed in (CDK output: AwsRegion).
VITE_AWS_REGION=ca-central-1

# Cognito User Pool id (CDK output: UserPoolId).
VITE_USER_POOL_ID=ca-central-1_xxxxxxxxx

# Cognito User Pool app client id (CDK output: UserPoolClientId).
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# AppSync GraphQL endpoint URL (CDK output: GraphQLApiUrl).
VITE_GRAPHQL_API_URL=https://xxxxxxxxxxxxxxxxxxxxxxxxxx.appsync-api.ca-central-1.amazonaws.com/graphql
